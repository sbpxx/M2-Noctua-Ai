<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="../css/style.css?v=<%= Date.now() %>">
<link
    href="https://cdn.jsdelivr.net/npm/remixicon@4.7.0/fonts/remixicon.css"
    rel="stylesheet"
/>
    <title>Chat</title>
</head>

<body>
    <%- include('partials/login') %>
    <%- include('partials/message') %>
    <%- include('partials/settings') %>
    <%- include('partials/search') %>
    <%- include('partials/archive') %>
    <%- include('partials/rename') %>
    <%- include('partials/users-management') %>
    <%- include('partials/logs') %>
    <%- include('partials/sidebar') %>

    <main class="chat-main">
        <div id="main-chat" class="main-chat">
            <div id="chat-container" class="chat-container">
                <!-- Messages inserées ici -->
            </div>
            <div class="chat-input-area">
                <input type="text" id="chat-input" placeholder="Tapez votre message..." />
                <button id="send-btn">Envoyer</button>
            </div>
        </div>

        <!-- Sidebar Sources -->
        <aside id="sources-sidebar" class="sources-sidebar">
            <div class="sources-header">
                <h3><i class="ri-book-open-line"></i> Sources</h3>
                <button id="close-sources-btn" class="close-sources-btn">
                    <i class="ri-close-line"></i>
                </button>
            </div>
            <div id="sources-container" class="sources-container">
                <p class="sources-empty">Les sources citées apparaîtront ici.</p>
            </div>
        </aside>

        <!-- Bouton pour ouvrir les sources -->
        <button id="open-sources-btn" class="open-sources-btn">
            <i class="ri-book-open-line"></i>
            <span class="sources-count" id="sources-count">0</span>
        </button>
    </main>

    <script src="https://cdn.socket.io/4.0.0/socket.io.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="../js/utils.js?v=<%= Date.now() %>"></script>
    <script src="../js/partial.js?v=<%= Date.now() %>"></script>
    <script src="../js/chat.js?v=<%= Date.now() %>"></script>
</body>

</html>