<div class="modal-rename" id="renameModal">
    <div class="modal-overlay" onclick="closeRenameModal()"></div>
    <div class="rename-modal-content">
        <h3><i class="ri-edit-line"></i> Modifier le titre</h3>
        <input type="text" id="rename-input" placeholder="Nouveau titre..." autocomplete="off" />
        <div class="rename-actions">
            <button class="rename-cancel-btn" onclick="closeRenameModal()">Annuler</button>
            <button class="rename-confirm-btn" id="rename-confirm-btn">Valider</button>
        </div>
    </div>
</div>
