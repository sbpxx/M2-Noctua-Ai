<div class="modal-logs" id="logsModal">
    <div class="modal-overlay"></div>
    <div class="logs-modal-content">
        <button class="modal-close" onclick="closeLogsModal()">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
        </button>

        <div class="logs-layout">
            <div class="logs-header">
                <div class="logs-icon">
                    <i class="ri-file-list-3-line"></i>
                </div>
                <h2>Logs d'administration</h2>
            </div>

            <div class="logs-info">
                <span id="logs-count">Chargement...</span>
                <button class="logs-refresh-btn" onclick="loadAdminLogs()">
                    <i class="ri-refresh-line"></i>
                </button>
            </div>

            <div class="logs-container" id="logs-container">
                <p class="logs-empty-state">Chargement des logs...</p>
            </div>
        </div>
    </div>
</div>
