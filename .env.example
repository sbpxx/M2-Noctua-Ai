# Configuration ECO Server (Mistral)
# Copier ce fichier en .env et remplir les valeurs
ECO_USER=your_username
ECO_HOST=your_host_ip
ECO_PASS=your_password

# JWT Secret Key
JWT_SECRET=your_jwt_secret_key

# API RAG - URL du service IA
# En local: http://172.31.60.144:5000/api/chat (serveur distant)
# Sur le serveur distant: http://127.0.0.1:5000/api/chat (localhost)
RAG_API_URL=http://172.31.60.144:5000/api/chat
